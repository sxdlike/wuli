# 物历 App 后端配置文件
# 复制此文件为 .env 并填入真实值

# AI API 密钥（必填，用于调用大模型）
# 支持 OpenAI 兼容格式的 API，如 DeepSeek、通义千问、智谱等
AI_API_KEY=your_api_key_here

# AI API 地址（可选，默认 DeepSeek）
# DeepSeek: https://api.deepseek.com/chat/completions
# 通义千问: https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
# 智谱: https://open.bigmodel.cn/api/paas/v4/chat/completions
AI_API_URL=https://api.deepseek.com/chat/completions

# AI 模型名称（可选，默认 deepseek-chat）
AI_MODEL=deepseek-chat

# 单次回复最大 token 数（可选，默认 500）
MAX_TOKENS=500

# 每日总调用上限（可选，默认 150）
DAILY_LIMIT=150

# 每 IP 每小时调用上限（可选，默认 8）
IP_HOURLY_LIMIT=8

# 允许的前端域名（可选，默认 * 允许所有）
# 部署后请改成你的实际域名，如 https://your-domain.com
ALLOWED_ORIGIN=*

# 服务端口（可选，默认 8080）
PORT=8080
